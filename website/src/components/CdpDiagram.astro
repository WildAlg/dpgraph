---
// Tiny static diagram for the Central DP threat model.
---
<div class="mini-diagram">
  <svg viewBox="0 0 220 90" class="w-full h-auto" role="img" aria-label="Central DP: users send raw adjacency lists to a trusted curator who outputs a single noisy statistic.">
    <g stroke="currentColor" fill="none" stroke-width="1">
      <circle cx="20" cy="20" r="5" fill="var(--bg)" />
      <circle cx="20" cy="45" r="5" fill="var(--bg)" />
      <circle cx="20" cy="70" r="5" fill="var(--bg)" />
      <line x1="25" y1="20" x2="100" y2="45" />
      <line x1="25" y1="45" x2="100" y2="45" />
      <line x1="25" y1="70" x2="100" y2="45" />
    </g>
    <rect x="100" y="32" width="60" height="28" rx="3" fill="var(--bg)" stroke="currentColor" stroke-width="1" />
    <text x="130" y="49" text-anchor="middle" font-size="9" fill="currentColor" class="font-mono" opacity="0.85">CURATOR</text>
    <text x="130" y="22" text-anchor="middle" font-size="8" fill="currentColor" class="font-mono" opacity="0.55">trusted</text>
    <line x1="160" y1="46" x2="195" y2="46" stroke="var(--accent)" stroke-width="1.2" />
    <text x="200" y="49" font-size="9" fill="var(--accent)" class="font-mono">f(G)+ξ</text>
    <text x="20" y="86" text-anchor="middle" font-size="8" fill="currentColor" class="font-mono" opacity="0.55">raw</text>
  </svg>
</div>
