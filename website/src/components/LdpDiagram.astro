---
// Tiny static diagram for the LDP / RR threat model.
---
<div class="mini-diagram">
  <svg viewBox="0 0 220 90" class="w-full h-auto" role="img" aria-label="LDP: each user flips edge bits via randomized response and only a noisy adjacency reaches the curator.">
    <g>
      <circle cx="20" cy="20" r="5" fill="var(--bg)" stroke="currentColor" stroke-width="1" />
      <circle cx="20" cy="45" r="5" fill="var(--bg)" stroke="currentColor" stroke-width="1" />
      <circle cx="20" cy="70" r="5" fill="var(--bg)" stroke="currentColor" stroke-width="1" />
      <!-- noise badges next to users -->
      <rect x="32" y="14" width="22" height="12" rx="2" fill="var(--bg)" stroke="var(--noise)" stroke-width="0.7" />
      <text x="43" y="23" text-anchor="middle" font-size="7" class="font-mono" fill="var(--noise)">RR</text>
      <rect x="32" y="39" width="22" height="12" rx="2" fill="var(--bg)" stroke="var(--noise)" stroke-width="0.7" />
      <text x="43" y="48" text-anchor="middle" font-size="7" class="font-mono" fill="var(--noise)">RR</text>
      <rect x="32" y="64" width="22" height="12" rx="2" fill="var(--bg)" stroke="var(--noise)" stroke-width="0.7" />
      <text x="43" y="73" text-anchor="middle" font-size="7" class="font-mono" fill="var(--noise)">RR</text>
      <line x1="56" y1="20" x2="100" y2="45" stroke="currentColor" stroke-width="1" stroke-dasharray="2 2" opacity="0.7" />
      <line x1="56" y1="45" x2="100" y2="45" stroke="currentColor" stroke-width="1" stroke-dasharray="2 2" opacity="0.7" />
      <line x1="56" y1="70" x2="100" y2="45" stroke="currentColor" stroke-width="1" stroke-dasharray="2 2" opacity="0.7" />
    </g>
    <rect x="100" y="32" width="60" height="28" rx="3" fill="var(--bg)" stroke="currentColor" stroke-width="1" stroke-dasharray="3 3" />
    <text x="130" y="49" text-anchor="middle" font-size="9" fill="currentColor" class="font-mono" opacity="0.85">CURATOR</text>
    <text x="130" y="22" text-anchor="middle" font-size="8" fill="currentColor" class="font-mono" opacity="0.55">untrusted</text>
    <line x1="160" y1="46" x2="195" y2="46" stroke="var(--accent)" stroke-width="1.2" />
    <text x="200" y="49" font-size="9" fill="var(--accent)" class="font-mono">f(G̃)</text>
  </svg>
</div>
