---
import ThemeToggle from "./ThemeToggle.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const { current } = Astro.props as { current?: "docs" | "paper" | "home" };
const link = (href: string) => `${base}${href}`;
---

<header class="sticky top-0 z-30 backdrop-blur-md" style="background: color-mix(in srgb, var(--bg) 86%, transparent); border-bottom: 1px solid var(--rule);">
  <div class="container-wide flex h-14 items-center justify-between gap-6">
    <a href={link("/")} class="group inline-flex items-center gap-2.5 no-underline" aria-label="dpgraph home">
      <svg viewBox="0 0 32 32" class="h-5 w-5" aria-hidden="true">
        <circle cx="6" cy="8" r="2.4" fill="currentColor"></circle>
        <circle cx="26" cy="8" r="2.4" fill="currentColor"></circle>
        <circle cx="6" cy="24" r="2.4" fill="currentColor"></circle>
        <circle cx="26" cy="24" r="2.4" fill="currentColor"></circle>
        <circle cx="16" cy="16" r="2.4" fill="var(--accent)"></circle>
        <line x1="6" y1="8" x2="16" y2="16" stroke="currentColor" stroke-width="0.9" />
        <line x1="26" y1="8" x2="16" y2="16" stroke="currentColor" stroke-width="0.9" />
        <line x1="6" y1="24" x2="16" y2="16" stroke="currentColor" stroke-width="0.9" />
        <line x1="26" y1="24" x2="16" y2="16" stroke="currentColor" stroke-width="0.9" />
        <line x1="6" y1="8" x2="6" y2="24" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2" opacity="0.5" />
        <line x1="26" y1="8" x2="26" y2="24" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2" opacity="0.5" />
      </svg>
      <span class="display text-lg leading-none tracking-tightish">dpgraph</span>
    </a>
    <nav aria-label="Primary" class="flex items-center gap-1">
      <a href={link("/docs/quickstart")} class={`px-3 py-1.5 text-[13px] no-underline rounded-full transition-colors hover:bg-[color:var(--code-bg)] ${current === "docs" ? "text-[color:var(--accent)]" : ""}`}>Docs</a>
      <a href={link("/docs/algorithms/k-core-ledp")} class={`px-3 py-1.5 text-[13px] no-underline rounded-full transition-colors hover:bg-[color:var(--code-bg)]`}>Algorithms</a>
      <a href={link("/paper")} class={`px-3 py-1.5 text-[13px] no-underline rounded-full transition-colors hover:bg-[color:var(--code-bg)] ${current === "paper" ? "text-[color:var(--accent)]" : ""}`}>Paper</a>
      <a href="https://github.com/WildAlg/dpgraph" rel="noreferrer" target="_blank" class="px-3 py-1.5 text-[13px] no-underline rounded-full transition-colors hover:bg-[color:var(--code-bg)] inline-flex items-center gap-1.5">
        GitHub
        <svg viewBox="0 0 24 24" class="h-3 w-3 opacity-60" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M7 17L17 7M9 7h8v8" />
        </svg>
      </a>
      <span class="mx-1 h-4 w-px" style="background: var(--rule);"></span>
      <ThemeToggle />
    </nav>
  </div>
</header>
