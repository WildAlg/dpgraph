---
// ThemeToggle — small icon button. Reads/writes localStorage('theme').
// Inline script runs before paint to prevent flash.
---

<button
  id="theme-toggle"
  type="button"
  aria-label="Toggle color theme"
  class="inline-flex h-8 w-8 items-center justify-center rounded-full border hairline transition-colors hover:bg-[color:var(--code-bg)]"
>
  <svg id="theme-toggle-sun" class="hidden h-[14px] w-[14px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
  </svg>
  <svg id="theme-toggle-moon" class="hidden h-[14px] w-[14px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<script is:inline>
  (function () {
    const root = document.documentElement;
    function apply(theme) {
      if (theme === "dark") root.classList.add("dark");
      else root.classList.remove("dark");
      const sun = document.getElementById("theme-toggle-sun");
      const moon = document.getElementById("theme-toggle-moon");
      if (sun && moon) {
        // show the icon for the *next* theme
        sun.classList.toggle("hidden", theme === "light");
        moon.classList.toggle("hidden", theme === "dark");
      }
    }
    function current() {
      const saved = localStorage.getItem("theme");
      if (saved) return saved;
      return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
    }
    apply(current());
    document.addEventListener("click", function (e) {
      const t = e.target;
      if (!t || !(t.closest && t.closest("#theme-toggle"))) return;
      const next = root.classList.contains("dark") ? "light" : "dark";
      localStorage.setItem("theme", next);
      apply(next);
    });
  })();
</script>
