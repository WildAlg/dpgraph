---
// Tiny static diagram for the LEDP threat model used by this work.
// Multi-round, structure-aware. Public state shared between rounds.
---
<div class="mini-diagram">
  <svg viewBox="0 0 220 90" class="w-full h-auto" role="img" aria-label="LEDP: users run epsilon-local randomizers each round; the curator publishes structural state used to tighten subsequent rounds.">
    <g>
      <circle cx="20" cy="20" r="5" fill="var(--bg)" stroke="currentColor" stroke-width="1" />
      <circle cx="20" cy="45" r="5" fill="var(--bg)" stroke="currentColor" stroke-width="1" />
      <circle cx="20" cy="70" r="5" fill="var(--bg)" stroke="currentColor" stroke-width="1" />
      <!-- per-user epsilon-LR badges -->
      <rect x="32" y="14" width="22" height="12" rx="2" fill="var(--bg)" stroke="var(--noise)" stroke-width="0.7" />
      <text x="43" y="23" text-anchor="middle" font-size="7" class="font-mono" fill="var(--noise)">ε-LR</text>
      <rect x="32" y="39" width="22" height="12" rx="2" fill="var(--bg)" stroke="var(--noise)" stroke-width="0.7" />
      <text x="43" y="48" text-anchor="middle" font-size="7" class="font-mono" fill="var(--noise)">ε-LR</text>
      <rect x="32" y="64" width="22" height="12" rx="2" fill="var(--bg)" stroke="var(--noise)" stroke-width="0.7" />
      <text x="43" y="73" text-anchor="middle" font-size="7" class="font-mono" fill="var(--noise)">ε-LR</text>
      <line x1="56" y1="20" x2="100" y2="45" stroke="var(--accent)" stroke-width="1" />
      <line x1="56" y1="45" x2="100" y2="45" stroke="var(--accent)" stroke-width="1" />
      <line x1="56" y1="70" x2="100" y2="45" stroke="var(--accent)" stroke-width="1" />
    </g>
    <rect x="100" y="32" width="60" height="28" rx="3" fill="var(--bg)" stroke="var(--accent)" stroke-width="1" />
    <text x="130" y="48" text-anchor="middle" font-size="9" fill="currentColor" class="font-mono" opacity="0.85">CURATOR</text>
    <text x="130" y="22" text-anchor="middle" font-size="8" fill="currentColor" class="font-mono" opacity="0.55">multi-round LDS</text>
    <!-- public state loop back to users -->
    <path d="M 100 60 Q 80 80 56 75" fill="none" stroke="currentColor" stroke-width="0.8" stroke-dasharray="2 2" opacity="0.65" />
    <path d="M 56 75 l 4 -2 l 0 4 z" fill="currentColor" opacity="0.65" />
    <text x="78" y="89" text-anchor="middle" font-size="7" fill="currentColor" class="font-mono" opacity="0.6">public state</text>
    <line x1="160" y1="46" x2="195" y2="46" stroke="var(--accent)" stroke-width="1.2" />
    <text x="200" y="49" font-size="9" fill="var(--accent)" class="font-mono">f(d,Dₘₐₓ)</text>
  </svg>
</div>
