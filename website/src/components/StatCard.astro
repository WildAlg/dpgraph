---
interface Props {
  value: string;
  unit?: string;
  label: string;
  caption?: string;
  emphasis?: boolean;
}

const { value, unit, label, caption, emphasis = false } = Astro.props;
---

<div class="rounded-md border hairline p-6" style="border-color: var(--rule);">
  <div class="small-caps">{label}</div>
  <div class="mt-3 flex items-baseline gap-2">
    <span class={`display tracking-tightish ${emphasis ? "text-[color:var(--accent)]" : ""}`} style="font-size: clamp(2.6rem, 5vw, 4rem); line-height: 0.95;">{value}</span>
    {unit ? <span class="display text-2xl" style="color: var(--muted);">{unit}</span> : null}
  </div>
  {caption ? <p class="mt-3 text-[13px] leading-relaxed" style="color: var(--muted);">{caption}</p> : null}
</div>
