---
import "../styles/globals.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  current?: "docs" | "paper" | "home";
  ogImage?: string;
}

const {
  title,
  description = "A Go framework for prototyping and benchmarking differentially private distributed graph algorithms. Companion artifact for the LEDP k-core and triangle-counting paper.",
  current = "home",
  ogImage,
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
const fullTitle = title === "dpgraph" ? "dpgraph — local-edge differentially private graph algorithms" : `${title} · dpgraph`;
const ogPath = ogImage ?? `${baseUrl}/og-image.svg`;
---

<!doctype html>
<html lang="en" class="">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogPath} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" href={`${baseUrl}/favicon.svg`} type="image/svg+xml" />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,700&display=swap"
    />
    <!-- pre-paint theme application to avoid flash -->
    <script is:inline>
      (function () {
        try {
          const saved = localStorage.getItem("theme");
          const theme = saved || (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
          if (theme === "dark") document.documentElement.classList.add("dark");
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-[color:var(--accent)] focus:px-3 focus:py-2 focus:text-white">Skip to content</a>
    <Nav current={current} />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
